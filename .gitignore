# Build artifacts (root-only — leading slash anchors at repo root so
# we don't accidentally exclude cmd/cradle/, etc.)
/bin/
/dist/
*.exe
*.test
*.out
/westworld
/cradle
/mesa
/delos

# Go workspace
go.work
go.work.sum
vendor/

# Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment
.env
.env.local

# Test coverage
*.cover
coverage.txt
coverage.html

# Local config / runtime data
/data/
/tmp/
*.db
*.sqlite
*.log

# Workshop / scratch space — see docs/lang/development-workflow.md
# Everything under /local/ is for experimentation, half-baked routines,
# REPL session captures, personal notes. Never committed. Promote to
# examples/routines/ or testdata/conformance/ when stable.
/local/
