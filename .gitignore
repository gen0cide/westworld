# Build artifacts (root-only — leading slash anchors at repo root so
# we don't accidentally exclude cmd/cradle/, etc.)
/bin/
/dist/
*.exe
*.test
*.out
/westworld
/delos
# cradle/ is a SOURCE package; the binaries it produces are ignored by name.
/cradle-server
/cradle-ctl
/legacy-cradle

# Go workspace
go.work
go.work.sum
vendor/

# Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Environment — any *.env file is treated as local secrets and never
# committed. The repo intentionally has NO committed env file;
# .local.env in the repo root is the conventional name for the dev
# launcher to source. No secret values appear in this file or any
# other committed artifact.
*.env
.env*

# Test coverage
*.cover
coverage.txt
coverage.html

# Local config / runtime data
/data/
/tmp/
*.db
*.sqlite
*.log

# Workshop / scratch space — see docs/lang/development-workflow.md
# Everything under /local/ is for experimentation, half-baked routines,
# REPL session captures, personal notes. Never committed. Promote to
# examples/routines/ or testdata/conformance/ when stable.
/local/
/scenariogen

# Pre-OpenRSC-port snapshot of the renderer (filesystem backup; git history also has it)
/_render.bak/

# Local cognitive-layer research scratch (untracked for now)
docs/_research/

# stray binaries from `go build` at the repo root — one root-anchored entry per
# cmd/* and mesa tool, so a built binary can never be committed by a broad add.
/host
/personacook
/wikirag
/wikitest
/dronegen
/scenariogen
/mesa-ctl
/orsc-ctl
/cradle-server
/cradle-ctl
/legacy-cradle
/defsgen
/parsecheck
/varrock-tiles
/mesad
/westworld
