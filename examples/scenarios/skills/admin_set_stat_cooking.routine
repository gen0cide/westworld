# Scenario: admin-set-stat-cooking
# Category: skills
# Hosts: any-drone
# Admin: required
# Timeout: 8s

routine admin_set_stat_cooking() {
    command("setstat 50 cooking")
    wait 1.5
    command("setcurrentstats 50 cooking")
    wait 1.5

    wait 2
    note(f"cooking_level={self.skills.cooking.level}")

    if self.skills.cooking.level >= 50 {
        return "PASS: admin-set-stat-cooking"
    }
    abort "FAIL: admin-set-stat-cooking (predicate was false)"
}
