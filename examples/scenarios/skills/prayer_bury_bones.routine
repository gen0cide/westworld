# Scenario: prayer-bury-bones
# Category: skills
# Hosts: any-drone
# Admin: required
# Timeout: 10s
#
# Notes: Bury action via inventory default — option-1 click on bones.

routine prayer_bury_bones() {
    command("item 20 1")
    wait 1.5

    prev_xp = self.skills.prayer.xp
    bones = inventory.find(20)
    if bones == null { abort "no bones in inventory" }
    use_inventory_default(bones)
    ok = wait_until(_ => self.skills.prayer.xp > prev_xp, 5)
    if not ok { abort f"prayer xp never rose (still {self.skills.prayer.xp})" }

    if self.skills.prayer.xp > 0 {
        return "PASS: prayer-bury-bones"
    }
    abort "FAIL: prayer-bury-bones (predicate was false)"
}
