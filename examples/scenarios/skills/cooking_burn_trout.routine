# Scenario: cooking-burn-trout
# Category: skills
# Hosts: any-drone
# Admin: required
# Timeout: 30s
#
# Notes: At cooking level 1, trout is guaranteed to burn — verifies the burnt-food path.

routine cooking_burn_trout() {
    command("setstat 1 cooking")
    wait 1.5
    command("setcurrentstats 1 cooking")
    wait 1.5
    command("item 14 1")
    wait 1.5
    command("item 166 1")
    wait 1.5
    command("item 358 1")
    wait 1.5

    use(inventory.find(166), inventory.find(14))  # light fire
    ok = wait_until(_ => world.ground_items.by_id(97) != null, 8)
    if not ok { abort "fire never appeared" }
    fire = world.ground_items.by_id(97)
    use(inventory.find(358), fire)
    ok2 = wait_until(_ => world.last_server_message.contains("burn") or inventory.find(359) != null, 15)
    if not ok2 { abort "cook never resolved" }

    if world.last_server_message.contains("burn") {
        return "PASS: cooking-burn-trout"
    }
    abort "FAIL: cooking-burn-trout (predicate was false)"
}
