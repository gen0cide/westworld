# Scenario: agility-gnome-rope-swing
# Category: skills
# Hosts: any-drone
# Admin: required
# Timeout: 20s

routine agility_gnome_rope_swing() {
    command("setstat 30 agility")
    wait 1.5
    command("setcurrentstats 30 agility")
    wait 1.5
    command("teleport 688 2395")
    wait 1.5

    obs = world.locs.search("rope").nearest(self.position)
    if obs == null { abort "no rope swing at gnome stronghold" }
    interact_at(obs)
    ok = wait_until(_ => world.last_server_message.contains("Agility experience") or self.skills.agility.xp > 0, 15)
    if not ok { abort "no agility xp" }

    if self.skills.agility.xp > 0 {
        return "PASS: agility-gnome-rope-swing"
    }
    abort "FAIL: agility-gnome-rope-swing (predicate was false)"
}
